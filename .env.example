# Suburbmates V1.1 - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# -------------------------------------------------------------
# SUPABASE CONFIGURATION
# -------------------------------------------------------------
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key for client-side operations
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key for server-side operations (keep secure!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database connection string (for migrations)
# DATABASE_URL=postgresql://username:password@db.your-project.supabase.co:5432/postgres

# -------------------------------------------------------------
# STRIPE CONFIGURATION (Manual Billing)
# -------------------------------------------------------------
# Stripe publishable key (optional, for frontend Payment Links if needed)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# NOTE: No Stripe Secret Keys are used in the codebase.
# The platform uses manual Stripe Payment Links and manual state toggles.

# -------------------------------------------------------------
# AUTHENTICATION CONFIGURATION
# -------------------------------------------------------------
# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here

# NextAuth URL (usually your app's base URL)
NEXTAUTH_URL=http://localhost:3000

# Auth providers configuration (if using additional providers)
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# -------------------------------------------------------------
# EMAIL CONFIGURATION
# -------------------------------------------------------------
# Resend API key (for transactional emails)
RESEND_API_KEY=your_resend_api_key_here

# From email address for notifications
FROM_EMAIL=noreply@suburbmates.com

# Support email address
SUPPORT_EMAIL=support@suburbmates.com

# -------------------------------------------------------------
# APPLICATION CONFIGURATION
# -------------------------------------------------------------
# Site URL (used for meta tags, email links, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Application environment
SUBURBMATES_ENV=development

# Maximum file upload size (in bytes)
MAX_FILE_SIZE=5242880  # 5MB

# Session timeout in minutes
SESSION_TIMEOUT=60

# -------------------------------------------------------------
# EXTERNAL API INTEGRATIONS
# -------------------------------------------------------------
# Australian Business Register (ABR) for ABN validation
ABR_GUID=your_abr_guid_here

# Mapbox token for suburb/LGA lookup or map components
MAPBOX_TOKEN=your_mapbox_token_here

# Cloudinary or other image hosting (if using)
# CLOUDINARY_CLOUD_NAME=your_cloud_name_here
# CLOUDINARY_API_KEY=your_api_key_here
# CLOUDINARY_API_SECRET=your_api_secret_here

# -------------------------------------------------------------
# MONITORING & ANALYTICS
# -------------------------------------------------------------
# Sentry DSN / configuration (for error tracking)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_PROFILES_SAMPLE_RATE=1

# PostHog API key (for analytics)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google Analytics (if using)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -------------------------------------------------------------
# Enable debug logging (development only)
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable feature flags (development only)
ENABLE_FEATURE_FLAGS=false

# -------------------------------------------------------------
# SECURITY SETTINGS
# -------------------------------------------------------------
# CSRF token secret
CSRF_SECRET=your_csrf_secret_here

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60000

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SYMBOLS=true
PASSWORD_REQUIRE_NUMBERS=true


# -------------------------------------------------------------
# BUSINESS RULES (Manual Billing — no automated checkout)
# -------------------------------------------------------------
# Maximum products per vendor (0 = unlimited)
MAX_PRODUCTS_PER_VENDOR=0

# Maximum featured listings per vendor
MAX_FEATURED_LISTINGS_PER_VENDOR=1


# -------------------------------------------------------------
# FILE STORAGE
# -------------------------------------------------------------
# Maximum file upload size for avatars (in bytes)
MAX_AVATAR_SIZE=2097152  # 2MB

# Maximum file upload size for product images (in bytes)
MAX_PRODUCT_IMAGE_SIZE=10485760  # 10MB

# Allowed image file types
NEXT_PUBLIC_ALLOWED_IMAGE_TYPES=["jpg", "jpeg", "png", "webp"]

# -------------------------------------------------------------
# NOTIFICATION SETTINGS
# -------------------------------------------------------------
# Email sending delay (in milliseconds)
EMAIL_SENDING_DELAY=1000

# Notification retention period (in days)
NOTIFICATION_RETENTION_DAYS=365

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable push notifications (if implemented)
ENABLE_PUSH_NOTIFICATIONS=false

# -------------------------------------------------------------
# COMPLIANCE & LEGAL
# -------------------------------------------------------------
# Privacy policy URL
PRIVACY_POLICY_URL=https://suburbmates.com/privacy

# Terms of service URL
TERMS_OF_SERVICE_URL=https://suburbmates.com/terms

# Cookie policy URL
COOKIE_POLICY_URL=https://suburbmates.com/cookies

# Data retention period (in days)
DATA_RETENTION_DAYS=2555  # 7 years for Australian compliance

# -------------------------------------------------------------
# INSTRUCTIONS
# -------------------------------------------------------------
#
# 1. Copy this file to .env.local
# 2. Replace all placeholder values with your actual credentials
# 3. Keep .env.local secure and never commit it to version control
# 4. Restart your development server after making changes
# 5. For production, set up equivalent environment variables in your deployment platform
#
# REQUIRED VARIABLES FOR BASIC FUNCTIONALITY:
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - NEXTAUTH_SECRET
# - NEXTAUTH_URL
#
# For more information, see: v1.1-docs/06_OPERATIONS_AND_DEPLOYMENT/
